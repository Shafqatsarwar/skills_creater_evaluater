{
  "name": "modern-ai-era-skills-system",
  "version": "2.0.0",
  "description": "Modern AI-Era Skills Creation and Evaluation System - Comprehensive platform for creating and evaluating skills with both AI and non-AI methodologies",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --exec \"npm run build && npm start\"",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "skills:create": "ts-node src/cli/skill-creator.ts",
    "skills:list": "node dist/index.js list",
    "skills:evaluate": "node dist/index.js evaluate"
  },
  "keywords": [
    "skills",
    "evaluation",
    "assessment",
    "education",
    "ai",
    "non-ai",
    "learning",
    "training",
    "professional-development"
  ],
  "author": "Modern Skills Initiative",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.0.0",
    "@types/node": "^18.0.0",
    "@types/express": "^4.17.17",
    "zod": "^3.22.4",
    "cors": "^2.8.5",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "ts-node": "^10.9.2"
  }
}